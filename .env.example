# Google AI (Gemini) API Key — get from aistudio.google.com
GOOGLE_API_KEY=your_google_api_key_here

# Tavily Search API Key — get from tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Optional: override the no-reply threshold (default is 7 days)
# DAYS_THRESHOLD=7

# Optional: path to Gmail credentials file (default: credentials.json in project root)
# GMAIL_CREDENTIALS_FILE=credentials.json
